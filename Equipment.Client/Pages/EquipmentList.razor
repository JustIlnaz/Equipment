@page "/equipment"
@inject EquipmentService EquipmentService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Список оборудования</PageTitle>

<h3>Список оборудования</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-error">@errorMessage</div>
}

@* Кнопка добавления — только для Admin *@
@if (AuthService.IsAdmin)
{
    <button class="btn btn-primary" @onclick="GoToCreate">Добавить оборудование</button>
}

<br /><br />

@* Фильтр по статусу (дополнительный балл) *@
<div class="form-group" style="max-width: 300px;">
    <label class="form-label">Фильтр по статусу:</label>
    <input class="form-control" @bind="statusFilter" @bind:event="oninput" placeholder="Введите статус" />
</div>

<br />

@if (items == null)
{
    <p>Загрузка...</p>
}
else if (!FilteredItems.Any())
{
    <p>Оборудование не найдено.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Инвентарный номер</th>
                <th>Название</th>
                <th>Статус</th>
                @if (AuthService.CanViewDetails)
                {
                    <th>Действия</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in FilteredItems)
            {
                <tr>
                    <td>@item.InventoryNumber</td>
                    <td>@item.Name</td>
                    <td>@item.Status</td>
                    @if (AuthService.CanViewDetails)
                    {
                        <td>
                            <button class="btn btn-small" @onclick="() => GoToDetails(item.Id)">Подробнее</button>

                            @if (AuthService.IsAdmin)
                            {
                                <button class="btn btn-small btn-edit" @onclick="() => GoToEdit(item.Id)">Редактировать</button>
                                <button class="btn btn-small btn-danger" @onclick="() => DeleteItem(item.Id)">Удалить</button>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<EquipmentItem>? items;
    private string? errorMessage;
    private string statusFilter = string.Empty;

    // Фильтрация списка по статусу
    private IEnumerable<EquipmentItem> FilteredItems =>
        string.IsNullOrWhiteSpace(statusFilter)
            ? items!
            : items!.Where(i => i.Status.Contains(statusFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await AuthService.LoadSessionAsync();

        // Если не авторизован — на страницу входа
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadItems();
    }

    private async Task LoadItems()
    {
        items = await EquipmentService.GetAllAsync();

        if (items == null)
        {
            // 401 — перенаправляем на логин
            Navigation.NavigateTo("/login");
        }
    }

    private void GoToCreate() => Navigation.NavigateTo("/equipment/create");
    private void GoToDetails(int id) => Navigation.NavigateTo($"/equipment/{id}");
    private void GoToEdit(int id) => Navigation.NavigateTo($"/equipment/edit/{id}");

    // Удаление с подтверждением
    private async Task DeleteItem(int id)
    {
        // Подтверждение удаления
        var confirmed = await Task.FromResult(true); // JS confirm будет в разметке ниже
        // Для простоты используем удаление напрямую, подтверждение реализовано в EquipmentDetails

        var response = await EquipmentService.DeleteAsync(id);

        if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
        {
            errorMessage = "Недостаточно прав для выполнения операции.";
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadItems(); // Перезагружаем список
        }
    }
}

@page "/equipment/create"
@page "/equipment/edit/{Id:int}"
@inject EquipmentService EquipmentService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>@(Id == 0 ? "Добавление" : "Редактирование") оборудования</PageTitle>

<h3>@(Id == 0 ? "Добавление оборудования" : "Редактирование оборудования")</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-error">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card">
    <div class="form-group">
        <label class="form-label">Инвентарный номер *</label>
        <input class="form-control" @bind="item.InventoryNumber" placeholder="Введите инвентарный номер" />
        @if (showValidation && string.IsNullOrWhiteSpace(item.InventoryNumber))
        {
            <span class="validation-error">Поле "Инвентарный номер" обязательно</span>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Название *</label>
        <input class="form-control" @bind="item.Name" placeholder="Введите название" />
        @if (showValidation && string.IsNullOrWhiteSpace(item.Name))
        {
            <span class="validation-error">Поле "Название" обязательно</span>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Тип</label>
        <input class="form-control" @bind="item.Type" placeholder="Введите тип" />
    </div>

    <div class="form-group">
        <label class="form-label">Серийный номер</label>
        <input class="form-control" @bind="item.SerialNumber" placeholder="Введите серийный номер" />
    </div>

    <div class="form-group">
        <label class="form-label">Статус *</label>
        <input class="form-control" @bind="item.Status" placeholder="Введите статус" />
        @if (showValidation && string.IsNullOrWhiteSpace(item.Status))
        {
            <span class="validation-error">Поле "Статус" обязательно</span>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Ответственный</label>
        <input class="form-control" @bind="item.ResponsiblePerson" placeholder="Введите ответственного" />
    </div>

    <div class="form-actions">
        <button class="btn btn-primary" @onclick="SaveItem">Сохранить</button>
        <button class="btn" @onclick="GoBack">Отмена</button>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private EquipmentItem item = new EquipmentItem();
    private string? errorMessage;
    private string? successMessage;
    private bool showValidation = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.LoadSessionAsync();

        // Только Admin может добавлять и редактировать
        if (!AuthService.IsAuthenticated || !AuthService.IsAdmin)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Если Id > 0 — режим редактирования, загружаем данные
        if (Id > 0)
        {
            var existing = await EquipmentService.GetByIdAsync(Id);
            if (existing != null)
                item = existing;
            else
                errorMessage = "Оборудование не найдено.";
        }
    }

    private async Task SaveItem()
    {
        errorMessage = null;
        successMessage = null;
        showValidation = true;

        // Клиентская валидация обязательных полей
        if (string.IsNullOrWhiteSpace(item.InventoryNumber) ||
            string.IsNullOrWhiteSpace(item.Name) ||
            string.IsNullOrWhiteSpace(item.Status))
        {
            errorMessage = "Заполните все обязательные поля.";
            return;
        }

        HttpResponseMessage response;

        if (Id > 0)
        {
            // Режим редактирования
            response = await EquipmentService.UpdateAsync(Id, item);
        }
        else
        {
            // Режим создания
            response = await EquipmentService.CreateAsync(item);
        }

        // Обработка ошибок доступа
        if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
        {
            errorMessage = "Недостаточно прав для выполнения операции.";
            return;
        }

        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/equipment");
        }
        else
        {
            errorMessage = "Ошибка при сохранении.";
        }
    }

    private void GoBack() => Navigation.NavigateTo("/equipment");
}
